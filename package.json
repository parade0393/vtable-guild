{
  "name": "vtable-guild",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "pnpm": ">=10.28.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:coverage": "vitest run --config ./vitest.config.ts --project core --project theme --project table --coverage",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "lint:style": "stylelint \"**/*.{css,scss,sass,less,vue,html}\" --fix",
    "format": "prettier --write --experimental-cli src/",
    "prepare": "husky",
    "preinstall": "npx only-allow pnpm",
    "commit": "git-cz",
    "commitlint": "commitlint --edit",
    "playground": "pnpm --filter @vtable-guild/playground dev",
    "site:dev": "pnpm --filter @vtable-guild/site dev",
    "site:build": "pnpm --filter @vtable-guild/site build",
    "site:preview": "pnpm --filter @vtable-guild/site preview",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm lint && pnpm type-check && pnpm test && pnpm build && changeset publish"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.3.0",
    "@tsconfig/node24": "^24.0.3",
    "@types/node": "^24.10.4",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitejs/plugin-vue-jsx": "^5.1.3",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "~10.6.2",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.2.7",
    "npm-run-all2": "^8.0.4",
    "postcss-html": "^1.8.0",
    "prettier": "3.7.4",
    "stylelint": "^16.26.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^39.0.1",
    "turbo": "^2.8.3",
    "typescript": "~5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.1"
  }
}
